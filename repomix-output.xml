    const monthName = `${MONTHS_BG[month]} ${year}`;
    const sorted = Object.keys(entries).sort();

    const wsData = [
      ['Shifster Solo — Отчет за работни часове'],
      [`Месец: ${monthName}  |  Потребител: ${state.profile?.full_name || 'Потребител'}`],
