/* =============================================
   Shifster Solo — style.css
   Design: Dark glassmorphism, Outfit + JetBrains Mono
   ============================================= */

/* ── Variables ── */
:root {
  --bg: #0e1832;
  --bg2: #091022;
  --surface: rgba(255, 255, 255, 0.04);
  --surface-solid: #111a36;
  --border: rgba(255, 255, 255, 0.08);
  --border-hover: rgba(255, 255, 255, 0.15);
  --text: #eeeef8;
  --text-dim: #7777aa;
  --text-muted: #4a4a6a;
  --accent: #4f8dff;
  --accent-rgb: 79, 141, 255;
  --green: #3ecf8e;
  --amber: #ffb347;
  --purple: #b08bff;
  --red: #ff5c7a;
  --radius: 16px;
  --radius-sm: 10px;
  --radius-xs: 6px;
  --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --shadow: 0 8px 40px rgba(0, 0, 0, 0.55);
  --shadow-sm: 0 2px 12px rgba(0, 0, 0, 0.3);
  --glass: blur(20px) saturate(1.4);
  --font: 'Outfit', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}

body.light-mode {
  --bg: #f2f2fa;
  --bg2: #e8e8f5;
  --surface: rgba(255, 255, 255, 0.75);
  --surface-solid: #ffffff;
  --border: rgba(0, 0, 0, 0.08);
  --border-hover: rgba(0, 0, 0, 0.15);
  --text: #0f0f20;
  --text-dim: #5555aa;
  --text-muted: #9999bb;
  --shadow: 0 8px 40px rgba(0, 0, 0, 0.10);
  --shadow-sm: 0 2px 12px rgba(0, 0, 0, 0.06);
}

/* ── Reset ── */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
}

[hidden] {
  display: none !important;
}

html.lock-scroll,
body.lock-scroll {
  overflow: hidden !important;
  height: 100vh !important;
  overscroll-behavior: none;
}

html, body { 
  overflow-x: hidden; 
  width: 100vw; 
}

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  transition: background var(--transition), color var(--transition);
  -webkit-font-smoothing: antialiased;
}

a {
  color: inherit;
  text-decoration: none;
}

input,
button,
select {
  font-family: inherit;
}

::-webkit-scrollbar {
  width: 5px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 99px;
}

/* ── Noise texture overlay ── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
}

/* ═══════════════════════════════════════
   AUTH SCREEN (High-End Access Gate)
═══════════════════════════════════════ */
.auth-screen {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem 1.5rem;
  background: radial-gradient(circle at 15% 15%, rgba(79, 141, 255, 0.1), transparent 45%),
              radial-gradient(circle at 85% 85%, rgba(176, 139, 255, 0.08), transparent 45%),
              #0e1832;
  position: relative;
  width: 100vw;
}

.auth-card {
  width: 100%;
  max-width: 460px; /* Slightly wider as requested */
  padding: 2.5rem 2rem;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(30px) saturate(1.8);
  -webkit-backdrop-filter: blur(30px) saturate(1.8);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 20px;
  box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.7);
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* On mobile, take up 90% of width up to the max-width */
@media (max-width: 480px) {
  .auth-card {
    width: 90%;
    padding: 2rem 1.5rem;
  }
}

.auth-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 1rem;
}

.auth-logo-img {
  height: 80px;
  width: auto;
  margin-bottom: 1.25rem;
  filter: drop-shadow(0 0 15px rgba(var(--accent-rgb), 0.3));
}

.auth-focus-text h1 {
  font-size: 1.65rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  margin-bottom: 0.5rem;
  background: linear-gradient(to bottom, #ffffff, #a0a0c0);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.2;
}

.auth-focus-text p {
  color: var(--text-dim);
  font-size: 0.95rem;
  font-weight: 400;
  margin-bottom: 1.75rem;
  line-height: 1.5;
}

/* Tabs */
.auth-tabs {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.4);
  padding: 6px;
  border-radius: 16px;
  margin-bottom: 1.25rem;
  border: 1px solid rgba(255, 255, 255, 0.05);
  width: 100%;
}

.auth-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.8rem 1rem;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text-dim);
  border-radius: 12px;
  background: transparent;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  height: 48px; /* Force robust uniform height */
}

.auth-tab.active {
  background: var(--accent);
  color: white;
  box-shadow: 0 4px 15px rgba(var(--accent-rgb), 0.3);
}

.auth-tab:not(.active):hover {
  color: var(--text);
  background: rgba(255, 255, 255, 0.05);
}

/* Forms */
.auth-form {
  display: none;
  flex-direction: column;
  gap: 1rem;
  width: 100%;
}

.auth-form.active {
  display: flex;
  animation: fadeIn 0.4s ease forwards;
}

.field-group {
  display: flex;
  flex-direction: column;
  text-align: left;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 1rem;
  font-size: 1.1rem;
  opacity: 0.6;
}

.input-wrapper input {
  width: 100%;
  padding: 1rem 1rem 1rem 3.5rem !important;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 14px;
  color: white;
  font-size: 0.95rem;
  transition: all 0.3s ease;
}

.input-wrapper input:focus {
  outline: none;
  border-color: var(--accent);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 0 4px rgba(var(--accent-rgb), 0.1);
}

.btn-lg {
  padding: 1rem !important;
  font-size: 1rem !important;
  font-weight: 700 !important;
  border-radius: 14px !important;
  margin-top: 0.5rem;
}

.btn-full {
  width: 100%;
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-dim);
  transition: all 0.3s ease;
  margin-top: 0.75rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-weight: 500;
}

.btn-ghost:hover {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  border-color: rgba(var(--accent-rgb), 0.4);
  transform: translateY(-1px);
}

/* Msg & Extra */
.auth-msg {
  margin-top: 0.5rem;
  text-align: center;
  font-size: 0.85rem;
  padding: 0.5rem;
  border-radius: 10px;
}

.resend-box {
  text-align: center;
  margin-top: 0.5rem;
}

/* Team Teaser */
.team-teaser {
  margin-top: 1rem;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  text-align: center;
}

.team-teaser p {
  font-size: 0.85rem;
  color: var(--text-muted);
}

.team-teaser span {
  color: var(--accent);
  font-weight: 600;
  opacity: 0.9;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
/* ═══════════════════════════════════════
   SUBSCRIPTION WALL (Paywall)
═══════════════════════════════════════ */
.subscription-wall {
