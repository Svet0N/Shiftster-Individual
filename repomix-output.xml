        btn.className = 'shift-tag custom-tpl';
        btn.dataset.start = tpl.start;
        btn.dataset.end = tpl.end;
        btn.dataset.name = tpl.name;
        btn.style.whiteSpace = 'nowrap';
        btn.style.flexShrink = '0';
